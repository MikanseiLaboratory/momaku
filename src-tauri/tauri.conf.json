{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "momaku",
  "version": "0.1.0",
  "identifier": "com.flowing.momaku",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "momaku",
        "width": 1100,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJCMjlBODZDQTFBRTlBOEIKUldTTG1xNmhiS2dwSy9RSi8wcXpDQmZxalJpM1VpdllXWFp2Q0M3RktTZERZK2IwUUh2czk1RHMK",
      "endpoints": [
        "https://github.com/MikanseiLaboratory/momaku/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
